<?xml version="1.0"?>
<robot name="tidybot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       TidyBot — Home Tidying Robot
       4-wheeled skid-steer base, torso, 3-DOF arm (right actuated,
       left cosmetic), LED face panel, camera + LiDAR sensors.
       ============================================================ -->

  <!-- ==================== PROPERTIES ==================== -->
  <xacro:property name="PI" value="3.14159265358979"/>

  <!-- Base dimensions -->
  <xacro:property name="base_length"  value="0.50"/>
  <xacro:property name="base_width"   value="0.45"/>
  <xacro:property name="base_height"  value="0.12"/>
  <xacro:property name="base_mass"    value="8.0"/>

  <!-- Wheel dimensions -->
  <xacro:property name="wheel_radius" value="0.07"/>
  <xacro:property name="wheel_width"  value="0.05"/>
  <xacro:property name="wheel_mass"   value="0.8"/>
  <!-- Wheel x offset from base center -->
  <xacro:property name="wheel_x_off"  value="0.16"/>
  <!-- Wheel y offset: half base width + half wheel width -->
  <xacro:property name="wheel_y_off"  value="0.25"/>

  <!-- Torso dimensions -->
  <xacro:property name="torso_radius" value="0.08"/>
  <xacro:property name="torso_height" value="0.55"/>
  <xacro:property name="torso_mass"   value="3.5"/>

  <!-- Arm link dimensions -->
  <xacro:property name="upper_arm_len"  value="0.22"/>
  <xacro:property name="upper_arm_r"    value="0.025"/>
  <xacro:property name="upper_arm_mass" value="0.6"/>

  <xacro:property name="forearm_len"    value="0.20"/>
  <xacro:property name="forearm_r"      value="0.022"/>
  <xacro:property name="forearm_mass"   value="0.45"/>

  <xacro:property name="hand_len"       value="0.10"/>
  <xacro:property name="hand_r"         value="0.020"/>
  <xacro:property name="hand_mass"      value="0.25"/>

  <!-- Gripper -->
  <xacro:property name="finger_len"     value="0.06"/>
  <xacro:property name="finger_w"       value="0.015"/>
  <xacro:property name="finger_h"       value="0.012"/>
  <xacro:property name="finger_mass"    value="0.05"/>

  <!-- Head / LED face -->
  <xacro:property name="face_w"  value="0.18"/>
  <xacro:property name="face_h"  value="0.12"/>
  <xacro:property name="face_d"  value="0.02"/>
  <xacro:property name="face_mass" value="0.15"/>

  <!-- Camera -->
  <xacro:property name="cam_w"  value="0.04"/>
  <xacro:property name="cam_h"  value="0.03"/>
  <xacro:property name="cam_d"  value="0.03"/>
  <xacro:property name="cam_mass" value="0.08"/>

  <!-- LiDAR -->
  <xacro:property name="lidar_r" value="0.035"/>
  <xacro:property name="lidar_h" value="0.04"/>
  <xacro:property name="lidar_mass" value="0.18"/>

  <!-- ==================== INERTIA MACROS ==================== -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m/12.0*(h*h+d*d)}"
        ixy="0" ixz="0"
        iyy="${m/12.0*(w*w+d*d)}"
        iyz="0"
        izz="${m/12.0*(w*w+h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m/12.0*(3*r*r+h*h)}"
        ixy="0" ixz="0"
        iyy="${m/12.0*(3*r*r+h*h)}"
        iyz="0"
        izz="${m/2.0*r*r}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${2.0/5.0*m*r*r}"
        ixy="0" ixz="0"
        iyy="${2.0/5.0*m*r*r}"
        iyz="0"
        izz="${2.0/5.0*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================== WHEEL MACRO ==================== -->
  <xacro:macro name="wheel" params="name x_sign y_sign">
    <link name="${name}_wheel">
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="${name}_wheel_rubber">
          <color rgba="0.1 0.1 0.1 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <origin xyz="${x_sign*wheel_x_off} ${y_sign*wheel_y_off} ${-base_height/2.0}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.05" friction="0.1"/>
    </joint>

    <gazebo reference="${name}_wheel">
      <material>Gazebo/DarkGrey</material>
      <mu1>1.2</mu1>
      <mu2>1.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
    </gazebo>
  </xacro:macro>

  <!-- ==================== ARM MACRO ==================== -->
  <!-- side: "right" or "left", y_sign: +1 or -1, actuated: true/false -->
  <xacro:macro name="robot_arm" params="side y_sign actuated">

    <!-- Shoulder joint -->
    <joint name="${side}_shoulder_joint" type="${actuated == 'true' and 'revolute' or 'fixed'}">
      <parent link="torso_link"/>
      <child  link="${side}_upper_arm"/>
      <origin xyz="0 ${y_sign*(torso_radius+0.01)} ${torso_height*0.35}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <xacro:if value="${actuated == 'true'}">
        <limit lower="-2.8" upper="0.3" effort="30.0" velocity="1.5"/>
        <dynamics damping="0.5" friction="0.2"/>
      </xacro:if>
    </joint>

    <link name="${side}_upper_arm">
      <xacro:cylinder_inertia m="${upper_arm_mass}" r="${upper_arm_r}" h="${upper_arm_len}"/>
      <visual>
        <origin xyz="0 0 ${-upper_arm_len/2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${upper_arm_r}" length="${upper_arm_len}"/>
        </geometry>
        <material name="${side}_upper_arm_color">
          <color rgba="0.6 0.6 0.65 1"/>
        </material>
      </visual>
      <!-- Shoulder housing visual -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.032"/>
        </geometry>
        <material name="${side}_shoulder_housing">
          <color rgba="0.3 0.3 0.35 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 ${-upper_arm_len/2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${upper_arm_r}" length="${upper_arm_len}"/>
        </geometry>
      </collision>
    </link>

    <!-- Elbow joint -->
    <joint name="${side}_elbow_joint" type="${actuated == 'true' and 'revolute' or 'fixed'}">
      <parent link="${side}_upper_arm"/>
      <child  link="${side}_forearm"/>
      <origin xyz="0 0 ${-upper_arm_len}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <xacro:if value="${actuated == 'true'}">
        <limit lower="-2.5" upper="0.1" effort="20.0" velocity="1.5"/>
        <dynamics damping="0.4" friction="0.15"/>
      </xacro:if>
    </joint>

    <link name="${side}_forearm">
      <xacro:cylinder_inertia m="${forearm_mass}" r="${forearm_r}" h="${forearm_len}"/>
      <visual>
        <origin xyz="0 0 ${-forearm_len/2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${forearm_r}" length="${forearm_len}"/>
        </geometry>
        <material name="${side}_forearm_color">
          <color rgba="0.6 0.6 0.65 1"/>
        </material>
      </visual>
      <!-- Elbow housing -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.028"/>
        </geometry>
        <material name="${side}_elbow_housing">
          <color rgba="0.3 0.3 0.35 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 ${-forearm_len/2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${forearm_r}" length="${forearm_len}"/>
        </geometry>
      </collision>
    </link>

    <!-- Wrist joint -->
    <joint name="${side}_wrist_joint" type="${actuated == 'true' and 'revolute' or 'fixed'}">
      <parent link="${side}_forearm"/>
      <child  link="${side}_hand"/>
      <origin xyz="0 0 ${-forearm_len}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <xacro:if value="${actuated == 'true'}">
        <limit lower="-1.57" upper="1.57" effort="10.0" velocity="2.0"/>
        <dynamics damping="0.3" friction="0.1"/>
      </xacro:if>
    </joint>

    <link name="${side}_hand">
      <xacro:cylinder_inertia m="${hand_mass}" r="${hand_r}" h="${hand_len}"/>
      <visual>
        <origin xyz="0 0 ${-hand_len/2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${hand_r}" length="${hand_len}"/>
        </geometry>
        <material name="${side}_hand_color">
          <color rgba="0.5 0.5 0.55 1"/>
        </material>
      </visual>
      <!-- Wrist housing -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.025"/>
        </geometry>
        <material name="${side}_wrist_housing">
          <color rgba="0.3 0.3 0.35 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 ${-hand_len/2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${hand_r}" length="${hand_len}"/>
        </geometry>
      </collision>
    </link>

    <!-- Gripper (only on actuated arm) -->
    <xacro:if value="${actuated == 'true'}">
      <!-- Left finger -->
      <joint name="${side}_finger_left_joint" type="prismatic">
        <parent link="${side}_hand"/>
        <child  link="${side}_finger_left"/>
        <origin xyz="${-finger_w-0.005} 0 ${-hand_len-finger_len/2.0}" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="0.0" upper="0.04" effort="5.0" velocity="0.1"/>
        <dynamics damping="0.1" friction="0.05"/>
      </joint>
      <link name="${side}_finger_left">
        <xacro:box_inertia m="${finger_mass}" w="${finger_w}" h="${finger_h}" d="${finger_len}"/>
        <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
            <box size="${finger_w} ${finger_h} ${finger_len}"/>
          </geometry>
          <material name="${side}_finger_left_color">
            <color rgba="0.8 0.4 0.1 1"/>
          </material>
        </visual>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
            <box size="${finger_w} ${finger_h} ${finger_len}"/>
          </geometry>
        </collision>
      </link>

      <!-- Right finger -->
      <joint name="${side}_finger_right_joint" type="prismatic">
        <parent link="${side}_hand"/>
        <child  link="${side}_finger_right"/>
        <origin xyz="${finger_w+0.005} 0 ${-hand_len-finger_len/2.0}" rpy="0 0 0"/>
        <axis xyz="-1 0 0"/>
        <limit lower="0.0" upper="0.04" effort="5.0" velocity="0.1"/>
        <dynamics damping="0.1" friction="0.05"/>
      </joint>
      <link name="${side}_finger_right">
        <xacro:box_inertia m="${finger_mass}" w="${finger_w}" h="${finger_h}" d="${finger_len}"/>
        <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
            <box size="${finger_w} ${finger_h} ${finger_len}"/>
          </geometry>
          <material name="${side}_finger_right_color">
            <color rgba="0.8 0.4 0.1 1"/>
          </material>
        </visual>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
            <box size="${finger_w} ${finger_h} ${finger_len}"/>
          </geometry>
        </collision>
      </link>
    </xacro:if>

    <!-- Cosmetic arm end cap (non-actuated) -->
    <xacro:unless value="${actuated == 'true'}">
      <joint name="${side}_endcap_joint" type="fixed">
        <parent link="${side}_hand"/>
        <child  link="${side}_endcap"/>
        <origin xyz="0 0 ${-hand_len}" rpy="0 0 0"/>
      </joint>
      <link name="${side}_endcap">
        <xacro:sphere_inertia m="0.05" r="0.022"/>
        <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><sphere radius="0.022"/></geometry>
          <material name="${side}_endcap_color">
            <color rgba="0.4 0.4 0.45 1"/>
          </material>
        </visual>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><sphere radius="0.022"/></geometry>
        </collision>
      </link>
    </xacro:unless>

    <!-- Gazebo materials for arm links -->
    <gazebo reference="${side}_upper_arm">
      <material>Gazebo/Grey</material>
    </gazebo>
    <gazebo reference="${side}_forearm">
      <material>Gazebo/Grey</material>
    </gazebo>
    <gazebo reference="${side}_hand">
      <material>Gazebo/DarkGrey</material>
    </gazebo>
  </xacro:macro>

  <!-- ==================== BASE FOOTPRINT ==================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <!-- base_link center is at wheel_radius + base_height/2 above ground -->
    <origin xyz="0 0 ${wheel_radius + base_height/2.0}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <xacro:box_inertia m="${base_mass}" w="${base_width}" h="${base_height}" d="${base_length}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="base_dark">
        <color rgba="0.2 0.2 0.22 1"/>
      </material>
    </visual>
    <!-- Bumper strip visual -->
    <visual>
      <origin xyz="${base_length/2.0-0.005} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 ${base_width} ${base_height*0.6}"/>
      </geometry>
      <material name="base_bumper">
        <color rgba="0.9 0.4 0.0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
  </gazebo>

  <!-- ==================== FOUR WHEELS ==================== -->
  <xacro:wheel name="front_left"  x_sign="1"  y_sign="1"/>
  <xacro:wheel name="front_right" x_sign="1"  y_sign="-1"/>
  <xacro:wheel name="rear_left"   x_sign="-1" y_sign="1"/>
  <xacro:wheel name="rear_right"  x_sign="-1" y_sign="-1"/>

  <!-- ==================== TORSO ==================== -->
  <joint name="torso_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="torso_link"/>
    <origin xyz="0 0 ${base_height/2.0 + torso_height/2.0}" rpy="0 0 0"/>
  </joint>

  <link name="torso_link">
    <xacro:cylinder_inertia m="${torso_mass}" r="${torso_radius}" h="${torso_height}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${torso_radius}" length="${torso_height}"/>
      </geometry>
      <material name="torso_color">
        <color rgba="0.25 0.25 0.28 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${torso_radius}" length="${torso_height}"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="torso_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ==================== HEAD / LED FACE ==================== -->
  <joint name="head_joint" type="fixed">
    <parent link="torso_link"/>
    <child  link="head_link"/>
    <origin xyz="0 0 ${torso_height/2.0 + face_h/2.0 + 0.01}" rpy="0 0 0"/>
  </joint>

  <link name="head_link">
    <xacro:box_inertia m="${face_mass}" w="${face_w}" h="${face_h}" d="${face_d}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${face_d} ${face_w} ${face_h}"/>
      </geometry>
      <material name="led_face">
        <color rgba="0.0 0.8 1.0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${face_d} ${face_w} ${face_h}"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="head_link">
    <material>Gazebo/Cyan</material>
  </gazebo>

  <!-- ==================== CAMERA (on torso, facing forward) ==================== -->
  <joint name="camera_joint" type="fixed">
    <parent link="torso_link"/>
    <child  link="camera_link"/>
    <!-- Mounted on front face of torso, slightly above center -->
    <origin xyz="${torso_radius+cam_d/2.0} 0 ${torso_height*0.15}" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <xacro:box_inertia m="${cam_mass}" w="${cam_w}" h="${cam_h}" d="${cam_d}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_d} ${cam_w} ${cam_h}"/>
      </geometry>
      <material name="camera_body">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <!-- Lens -->
    <visual>
      <origin xyz="${cam_d/2.0+0.005} 0 0" rpy="0 ${PI/2} 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.008"/>
      </geometry>
      <material name="camera_lens">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_d} ${cam_w} ${cam_h}"/>
      </geometry>
    </collision>
  </link>

  <!-- Camera optical frame -->
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-PI/2} 0 ${-PI/2}"/>
  </joint>
  <link name="camera_optical_frame"/>

  <gazebo reference="camera_link">
    <material>Gazebo/Black</material>
    <sensor name="front_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>20.0</far>
        </clip>
      </camera>
      <topic>/camera/image_raw</topic>
      <gz_frame_id>camera_optical_frame</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- ==================== LIDAR (on top of torso) ==================== -->
  <joint name="lidar_joint" type="fixed">
    <parent link="torso_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 ${torso_height/2.0 + lidar_h/2.0}" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <xacro:cylinder_inertia m="${lidar_mass}" r="${lidar_r}" h="${lidar_h}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_r}" length="${lidar_h}"/>
      </geometry>
      <material name="lidar_body">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_r}" length="${lidar_h}"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <!-- ==================== ARMS ==================== -->
  <!-- Right arm: actuated (3-DOF + gripper) -->
  <xacro:robot_arm side="right" y_sign="1" actuated="true"/>

  <!-- Left arm: cosmetic (fixed joints, no gripper) -->
  <xacro:robot_arm side="left" y_sign="-1" actuated="false"/>

  <!-- ==================== GAZEBO PLUGINS ==================== -->

  <!-- Skid-steer drive plugin -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <!-- Using front wheels for primary drive, rear follow -->
      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>${wheel_y_off*2.0}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <max_angular_acceleration>4.0</max_angular_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>20</odom_publish_frequency>
    </plugin>

    <!-- Joint state publisher -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>

    <!-- Pose publisher for ground truth -->
    <plugin filename="gz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_nested_model_pose>true</publish_nested_model_pose>
      <update_frequency>10</update_frequency>
    </plugin>
  </gazebo>

</robot>
