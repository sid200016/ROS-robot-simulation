        </visual>
        <!-- Front wall -->
        <collision name="front_col">
          <pose>0 -0.275 0.175 0 0 0</pose>
          <geometry><box><size>0.6 0.05 0.30</size></box></geometry>
        </collision>
        <visual name="front">
          <pose>0 -0.275 0.175 0 0 0</pose>
