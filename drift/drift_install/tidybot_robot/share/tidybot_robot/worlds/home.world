          <pose>-0.275 0 0.175 0 0 0</pose>
          <geometry><box><size>0.05 0.6 0.30</size></box></geometry>
        </collision>
        <visual name="left">
          <pose>-0.275 0 0.175 0 0 0</pose>
          <geometry><box><size>0.05 0.6 0.30</size></box></geometry>
          <material><ambient>0.1 0.5 0.1 1</ambient><diffuse>0.1 0.6 0.1 1</diffuse></material>
