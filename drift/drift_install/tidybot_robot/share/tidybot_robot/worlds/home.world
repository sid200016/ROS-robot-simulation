    <!-- ============================================================
         SMALL PICKUP OBJECTS (7 objects across both rooms)
    ============================================================ -->

    <!-- Object 1: red block in Room 1 -->
    <model name="obj_block1">
      <pose>-4 -1.0 0.05 0 0 0</pose>
      <link name="link">
        <inertial><mass>0.1</mass><inertia><ixx>0.000042</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000042</iyy><iyz>0</iyz><izz>0.000042</izz></inertia></inertial>
        <collision name="col"><geometry><box><size>0.1 0.1 0.1</size></box></geometry><surface><friction><ode><mu>0.7</mu><mu2>0.7</mu2></ode></friction></surface></collision>
