    <!-- Object 6: purple cylinder in Room 2 -->
    <model name="obj_can2">
      <pose>5 1.5 0.06 0 0 0</pose>
      <link name="link">
        <inertial><mass>0.20</mass><inertia><ixx>0.000125</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000125</iyy><iyz>0</iyz><izz>0.000075</izz></inertia></inertial>
