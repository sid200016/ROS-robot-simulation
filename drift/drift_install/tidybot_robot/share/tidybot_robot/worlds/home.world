      <pose>3.5 1.0 0.05 0 0 0</pose>
      <link name="link">
        <inertial><mass>0.12</mass><inertia><ixx>0.000048</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000048</iyy><iyz>0</iyz><izz>0.000048</izz></inertia></inertial>
