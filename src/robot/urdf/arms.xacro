<?xml version='1.0'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="pickup_arm">

	<xacro:macro name="arm_mount" params="name parent x y z yaw">
		<link name="${name}_mount_link">
			<visual>
				<origin xyz="0 0 0" rpy="0 0 0" />
				<geometry>
					<box size="0.05 0.05 0.05" />
				</geometry>
				<material name="mount_gray">
					<color rgba="0.45 0.45 0.45 1.0"/>
				</material>
			</visual>
			<collision>
				<origin xyz="0 0 0" rpy="0 0 0" />
				<geometry>
					<box size="0.05 0.05 0.05" />
				</geometry>
			</collision>
			<xacro:box_inertial_from_mass
				l="0.05"
				w="0.05"
				h="0.05"
				mass="0.35" />
		</link>

		<joint name="${name}_mount_joint" type="fixed">
			<parent link="${parent}"/>
			<child link="${name}_mount_link"/>
			<origin xyz="${x} ${y} ${z}" rpy="0 0 ${yaw}" />
		</joint>
	</xacro:macro>

	<xacro:macro name="three_dof_arm" params="prefix parent mount_x mount_y mount_z mount_yaw shoulder_axis_y">
		<xacro:arm_mount name="${prefix}" parent="${parent}" x="${mount_x}" y="${mount_y}" z="${mount_z}" yaw="${mount_yaw}"/>

		<link name="${prefix}_upper_arm_link">
			<visual>
				<origin xyz="0.11 0 0" rpy="0 1.5708 0" />
				<geometry>
					<cylinder radius="0.028" length="0.22" />
				</geometry>
				<material name="arm_blue">
					<color rgba="0.18 0.42 0.78 1.0"/>
				</material>
			</visual>
			<collision>
				<origin xyz="0.11 0 0" rpy="0 1.5708 0" />
				<geometry>
					<cylinder radius="0.028" length="0.22" />
				</geometry>
			</collision>
			<xacro:cylinder_inertial_from_mass
				radius="0.028"
				length="0.22"
				mass="1.1"
				origin_xyz="0.11 0 0"
				origin_rpy="0 1.5708 0" />
		</link>

		<joint name="${prefix}_shoulder_joint" type="revolute">
			<parent link="${prefix}_mount_link"/>
			<child link="${prefix}_upper_arm_link"/>
			<origin xyz="0.025 0 0" rpy="0 0 0" />
			<axis xyz="0 ${shoulder_axis_y} 0"/>
			<limit lower="-1.57" upper="1.57" effort="22.0" velocity="1.5"/>
			<dynamics damping="0.5" friction="0.12"/>
		</joint>

		<link name="${prefix}_forearm_link">
			<visual>
				<origin xyz="0.10 0 0" rpy="0 1.5708 0" />
				<geometry>
					<cylinder radius="0.024" length="0.20" />
				</geometry>
				<material name="arm_cyan">
					<color rgba="0.15 0.7 0.8 1.0"/>
				</material>
			</visual>
			<collision>
				<origin xyz="0.10 0 0" rpy="0 1.5708 0" />
				<geometry>
					<cylinder radius="0.024" length="0.20" />
				</geometry>
			</collision>
			<xacro:cylinder_inertial_from_mass
				radius="0.024"
				length="0.20"
				mass="0.8"
				origin_xyz="0.10 0 0"
				origin_rpy="0 1.5708 0" />
		</link>

		<joint name="${prefix}_elbow_joint" type="revolute">
			<parent link="${prefix}_upper_arm_link"/>
			<child link="${prefix}_forearm_link"/>
			<origin xyz="0.22 0 0" rpy="0 0 0" />
			<axis xyz="0 ${shoulder_axis_y} 0"/>
			<limit lower="-2.355" upper="2.355" effort="18.0" velocity="1.6"/>
			<dynamics damping="0.4" friction="0.10"/>
		</joint>

		<link name="${prefix}_wrist_link">
			<visual>
				<origin xyz="0.06 0 0" rpy="0 1.5708 0" />
				<geometry>
					<cylinder radius="0.018" length="0.12" />
				</geometry>
				<material name="arm_blue"/>
			</visual>
			<collision>
				<origin xyz="0.06 0 0" rpy="0 1.5708 0" />
				<geometry>
					<cylinder radius="0.018" length="0.12" />
				</geometry>
			</collision>
			<xacro:cylinder_inertial_from_mass
				radius="0.018"
				length="0.12"
				mass="0.35"
				origin_xyz="0.06 0 0"
				origin_rpy="0 1.5708 0" />
		</link>

		<joint name="${prefix}_wrist_joint" type="revolute">
			<parent link="${prefix}_forearm_link"/>
			<child link="${prefix}_wrist_link"/>
			<origin xyz="0.20 0 0" rpy="0 0 0" />
			<axis xyz="0 ${shoulder_axis_y} 0"/>
			<limit lower="-1.57" upper="1.57" effort="10.0" velocity="2.0"/>
			<dynamics damping="0.25" friction="0.08"/>
		</joint>

		<link name="${prefix}_magnet_link">
			<visual>
				<origin xyz="0.02 0 0" rpy="0 1.5708 0" />
				<geometry>
					<cylinder radius="0.03" length="0.03" />
				</geometry>
				<material name="magnet_red">
					<color rgba="0.78 0.12 0.12 1.0"/>
				</material>
			</visual>
			<collision>
				<origin xyz="0.02 0 0" rpy="0 1.5708 0" />
				<geometry>
					<cylinder radius="0.03" length="0.03" />
				</geometry>
			</collision>
			<xacro:cylinder_inertial_from_mass
				radius="0.03"
				length="0.03"
				mass="0.15"
				origin_xyz="0.02 0 0"
				origin_rpy="0 1.5708 0" />
		</link>

		<joint name="${prefix}_magnet_joint" type="fixed">
			<parent link="${prefix}_wrist_link"/>
			<child link="${prefix}_magnet_link"/>
			<origin xyz="0.12 0 0" rpy="0 0 0" />
		</joint>
	</xacro:macro>

	<xacro:macro name="left_arm" params="parent">
		<xacro:three_dof_arm
			prefix="left_arm"
			parent="${parent}"
			mount_x="0.0"
			mount_y="${torso_width / 2.0 + 0.025}"
			mount_z="${torso_height / 2.0 -0.025}"
			mount_yaw="1.5708"
			shoulder_axis_y="1" />
	</xacro:macro>

	<xacro:macro name="right_arm" params="parent">
		<xacro:three_dof_arm
			prefix="right_arm"
			parent="${parent}"
			mount_x="0.0"
			mount_y="${-(torso_width / 2.0 + 0.025)}"
			mount_z="${torso_height / 2.0 -0.025}"
			mount_yaw="-1.5708"
			shoulder_axis_y="-1" />
	</xacro:macro>

</robot>
