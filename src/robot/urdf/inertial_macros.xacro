<?xml version='1.0'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Material densities in kg/m^3 -->
  <xacro:property name="steel_density" value="7850.0"/>
  <xacro:property name="aluminum_density" value="2700.0"/>
  <xacro:property name="plastic_density" value="1200.0"/>
  <xacro:property name="rubber_density" value="1100.0"/>

  <!-- Solid box inertial from density and box dimensions -->
  <xacro:macro name="box_inertial_from_density" params="l w h density origin_xyz:='0 0 0' origin_rpy:='0 0 0'">
    <xacro:property name="mass" value="${density * l * w * h}"/>
    <inertial>
      <origin xyz="${origin_xyz}" rpy="${origin_rpy}"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (w*w + h*h) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * (l*l + h*h) / 12.0}"
        iyz="0.0"
        izz="${mass * (l*l + w*w) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <!-- Solid box inertial from an explicit mass and box dimensions -->
  <xacro:macro name="box_inertial_from_mass" params="l w h mass origin_xyz:='0 0 0' origin_rpy:='0 0 0'">
    <inertial>
      <origin xyz="${origin_xyz}" rpy="${origin_rpy}"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (w*w + h*h) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * (l*l + h*h) / 12.0}"
        iyz="0.0"
        izz="${mass * (l*l + w*w) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <!-- Solid cylinder inertial from density and cylinder dimensions -->
  <xacro:macro name="cylinder_inertial_from_density" params="radius length density origin_xyz:='0 0 0' origin_rpy:='0 0 0'">
    <xacro:property name="mass" value="${density * 3.141592653589793 * radius * radius * length}"/>
    <inertial>
      <origin xyz="${origin_xyz}" rpy="${origin_rpy}"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (3.0 * radius * radius + length * length) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * (3.0 * radius * radius + length * length) / 12.0}"
        iyz="0.0"
        izz="${0.5 * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <!-- Solid cylinder inertial from an explicit mass and cylinder dimensions -->
  <xacro:macro name="cylinder_inertial_from_mass" params="radius length mass origin_xyz:='0 0 0' origin_rpy:='0 0 0'">
    <inertial>
      <origin xyz="${origin_xyz}" rpy="${origin_rpy}"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (3.0 * radius * radius + length * length) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * (3.0 * radius * radius + length * length) / 12.0}"
        iyz="0.0"
        izz="${0.5 * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

</robot>
